# Copy this file to .env and edit it for your deployment.
#
# Keep values in simple KEY=value form without shell quotes or spaces around
# "=". Explicit variables supplied when running ./startup.sh take precedence
# over this file. Docker Compose shell overrides take precedence for variables
# mapped in docker-compose.yml.
#
# CODA configuration lives in config/settings.yaml (one namespace per module).
# Any value there can be overridden with a CODA_-prefixed environment variable,
# using "__" (double underscore) to descend into nested keys. The variables
# below follow that scheme.
#
# Exceptions: OPENAI_API_KEY and SPEECHMATICS_API_KEY keep their conventional
# (non-CODA-prefixed) names.

# -----------------------------------------------------------------------------
# Inference LLM
# -----------------------------------------------------------------------------

# LLM provider used by the inference service and as the app's initial
# translation provider. Supported values: openai, openai-responses, ollama.
# "openai" uses Chat Completions, the portable choice that also works with
# OpenAI-compatible servers (e.g. mlx_lm.server, vLLM). "openai-responses" uses
# the OpenAI Responses API. Both honor OPENAI_BASE_URL.
CODA_INFERENCE__LLM__PROVIDER=openai

# Model name understood by the selected provider.
# OpenAI example: gpt-5.4-mini
# Ollama example: llama3.2
CODA_INFERENCE__LLM__MODEL=gpt-5.4-mini

# Required only when the provider is openai. Keeps its conventional name.
OPENAI_API_KEY=your-openai-api-key-here

# Optional override pointing the openai provider at any OpenAI-compatible
# endpoint (the API key is ignored by local servers that don't need one).
# Keeps its conventional name. Examples: a local Apple Silicon MLX server
# (mlx_lm.server / LM Studio), vLLM, or AWS Bedrock's native OpenAI-compatible
# endpoint (https://bedrock-mantle.<region>.api.aws/v1 with a Bedrock API key).
# OPENAI_BASE_URL=http://localhost:8080/v1

# Optional Ollama endpoint override.
#
# Leave this unset for the standard configurations:
# - ./startup.sh defaults to http://localhost:11434
# - Docker Compose defaults to http://host.docker.internal:11434
#
# Set it only when Ollama is running at another address. Do not set it to
# localhost for Docker Compose because localhost inside a container refers to
# that container, not the Docker host.
# CODA_LLM__OLLAMA__BASE_URL=http://ollama-server:11434

# -----------------------------------------------------------------------------
# CODA web app
# -----------------------------------------------------------------------------

# Interface and port where the web app listens.
# Keep the host 0.0.0.0 for Docker or remote access. Use 127.0.0.1 to restrict
# a local source deployment to the current machine.
CODA_APP__HOST=0.0.0.0
CODA_APP__PORT=8000

# -----------------------------------------------------------------------------
# Inference service
# -----------------------------------------------------------------------------

# Interface and port where the inference API listens.
# Keep the host 0.0.0.0 for Docker. The inference API is published on this port
# by the current Compose configuration.
CODA_INFERENCE__HOST=0.0.0.0
CODA_INFERENCE__PORT=5123

# URL used by the app to contact the inference service.
#
# Normally leave this unset:
# - ./startup.sh derives http://127.0.0.1:<CODA_INFERENCE__PORT>
# - Docker Compose derives http://inference:<CODA_INFERENCE__PORT>
#
# Set it when the app and inference service run on different hosts or outside
# the standard startup/Compose topology.
# CODA_INFERENCE__URL=http://inference-host:5123

# -----------------------------------------------------------------------------
# RAG grounder
# -----------------------------------------------------------------------------

# These settings are independent from the inference LLM provider/model. They are
# used only when the RAG grounder is selected.
CODA_GROUNDER__RAG__LLM__PROVIDER=openai
CODA_GROUNDER__RAG__LLM__MODEL=gpt-4o-mini

# Ontology vector index queried by the RAG grounder (icd10 | icd11).
CODA_GROUNDER__RAG__RETRIEVER__ONTOLOGY=icd10

# Whether the RAG grounder reranks retrieved candidates with its LLM.
CODA_GROUNDER__RAG__RERANKER__ENABLED=true

# URL used by the RAG grounder to contact Neo4j.
#
# Normally leave this unset:
# - local Python processes default to bolt://localhost:7687
# - Docker Compose defaults to bolt://kg:7687
#
# Set it when Neo4j runs on another host or outside the standard Compose
# topology.
# CODA_KG__URL=bolt://neo4j-host:7687

# -----------------------------------------------------------------------------
# Transcription backend
# -----------------------------------------------------------------------------

# Speech-to-text backend for the app/server. Supported values:
#   whisper-livekit  - low-latency in-process streaming (app/server default)
#   faster-whisper   - faster-whisper / CTranslate2
#   whisper          - OpenAI Whisper (PyTorch)
#   speechmatics     - Speechmatics realtime API
# The app/server defaults to whisper-livekit. The CLI is batch-oriented and
# defaults to faster-whisper instead (override with --transcriber). Uncomment to
# force a specific app/server backend.
# CODA_DIALOGUE__TRANSCRIBER_BACKEND=whisper-livekit

# Required only when the transcriber backend is speechmatics. Keeps its
# conventional name. If unset, the backend also falls back to reading a
# speechmatics_api_key file in the working directory (override the path with
# SPEECHMATICS_API_KEY_FILE).
# SPEECHMATICS_API_KEY=your-speechmatics-api-key-here

# Optional Speechmatics overrides. Defaults target the US realtime endpoint
# and the enhanced operating point. Use wss://eu.rt.speechmatics.com/v2/ for EU.
# CODA_DIALOGUE__SPEECHMATICS__URL=wss://us.rt.speechmatics.com/v2/
# CODA_DIALOGUE__SPEECHMATICS__MODEL=enhanced

# On Apple Silicon, whisper-livekit can run on the GPU via Apple MLX. Install
# mlx-whisper and set the whisper-livekit backend:
# CODA_DIALOGUE__WHISPER_LIVEKIT__BACKEND=mlx-whisper

# -----------------------------------------------------------------------------
# Whisper compute device
# -----------------------------------------------------------------------------

# Runtime device used by Whisper. Supported values: cpu, cuda.
# Leave unset for the CPU default. A CUDA deployment also requires a
# CUDA-capable PyTorch build and GPU access inside the container.
# CODA_DIALOGUE__DEVICE=cpu

# Docker app image build target. Supported values: cpu, cuda.
# This is a build argument consumed by Docker Compose, not a Python runtime
# setting. Changing it requires rebuilding the app image.
# COMPUTE_DEVICE=cpu

# -----------------------------------------------------------------------------
# Docker Compose host ports
# -----------------------------------------------------------------------------

# Ports published on the Docker host for the Neo4j browser and Bolt protocol.
# Change these when the defaults conflict with another host service. These do
# not change Neo4j's internal container ports.
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
