                      "fontFamily": "Inter",
                      "fontSize": 16,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "nfJKh",
                      "name": "obP2",
                      "fill": "$ink-soft",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "The output is advisory. Final cause-of-death determination remains with you — and, where applicable, with post-mortem confirmation.",
                      "lineHeight": 1.65,
                      "fontFamily": "Inter",
                      "fontSize": 16,
                      "fontWeight": "normal"
                    }
                  ]
