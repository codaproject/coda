                    {
                      "type": "text",
                      "id": "a8ecm",
                      "name": "reTrText",
                      "fill": "$ink-soft",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "My father had been feeling unwell for about a week before he died. He kept complaining about heaviness in his chest, especially when he walked up the stairs at home, but he refused to go to the doctor — he said he didn't want to be a bother. The morning he died he was sweating a lot, more than usual, and he looked pale. Around ten in the morning I heard him shout from the bathroom and found him on the floor, holding his left arm. Our neighbor helped me carry him to the car. He was breathing but in terrible pain. By the time we reached the clinic — about forty-five minutes later — he had stopped talking and his lips were turning blue. He had been told he had high blood pressure a few years ago…",
                      "lineHeight": 1.7,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    }
                  ]
                }
