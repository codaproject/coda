                    {
                      "type": "text",
                      "id": "zvMtc",
                      "name": "acP1",
                      "fill": "$ink-soft",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "My father had been feeling unwell for about a week before he died. He kept complaining about heaviness in his chest, especially when he walked up the stairs at home. But he refused to go to the doctor — he said he didn't want to be a bother.",
                      "lineHeight": 1.7,
                      "fontFamily": "Inter",
                      "fontSize": 19,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "ncS2x",
                      "name": "acP2",
                      "fill": "$ink-soft",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "The morning he died he was sweating a lot, more than usual, and he looked pale. He had breakfast but didn't finish it. Around ten in the morning I heard him shout from the bathroom. When I got to him, he was on the floor, holding his left arm.",
                      "lineHeight": 1.7,
                      "fontFamily": "Inter",
                      "fontSize": 19,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "frame",
                      "id": "dVkgG",
                      "name": "acPCur",
                      "width": "fill_container",
                      "gap": 16,
                      "children": [
                        {
                          "type": "frame",
                          "id": "XkciH",
                          "name": "acPCurBar",
                          "width": 3,
                          "height": "fill_container",
                          "fill": "$record-red",
                          "cornerRadius": 2
                        },
                        {
                          "type": "text",
                          "id": "gbv8L",
                          "name": "acPCurT",
                          "fill": "$ink",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "Our neighbor helped me carry him to the car. He was breathing, but in terrible pain. By the time we reached the clinic — it must have been forty-five minutes — he had stopped talking, and his lips were turning blue. The clinic staff tried to revive him for a long time, but he never woke up.",
                          "lineHeight": 1.7,
                          "fontFamily": "Inter",
                          "fontSize": 19,
                          "fontWeight": "500"
                        }
                      ]
                    },
                    {
                      "type": "text",
                      "id": "i03zn",
                      "name": "acPPartial",
                      "fill": "$ink-muted",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "He had been told he had high blood pressure a few years ago, but I think he stopped taking the tablets last year because…",
                      "lineHeight": 1.7,
                      "fontFamily": "Inter",
                      "fontSize": 19,
                      "fontWeight": "normal",
                      "fontStyle": "italic"
                    }
                  ]
                }
              ]
