            {
              "type": "frame",
              "id": "c91tZ",
              "name": "mTxBody",
              "width": "fill_container",
              "layout": "vertical",
              "gap": 18,
              "children": [
                {
                  "type": "text",
                  "id": "iUops",
                  "name": "mP1",
                  "fill": "$ink-soft",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "My father had been feeling unwell for about a week before he died. He kept complaining about heaviness in his chest, but he refused to go to the doctor.",
                  "lineHeight": 1.65,
                  "fontFamily": "Inter",
                  "fontSize": 16,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "mGbsR",
                  "name": "mP2",
                  "fill": "$ink-soft",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "The morning he died he was sweating a lot, and he looked pale. Around ten in the morning I heard him shout from the bathroom.",
                  "lineHeight": 1.65,
                  "fontFamily": "Inter",
                  "fontSize": 16,
                  "fontWeight": "normal"
                },
                {
                  "type": "frame",
                  "id": "HPh6k",
                  "name": "mPCur",
                  "width": "fill_container",
                  "gap": 12,
                  "children": [
                    {
                      "type": "frame",
                      "id": "boM3x",
                      "width": 3,
                      "height": "fill_container",
                      "fill": "$record-red",
                      "cornerRadius": 2
                    },
                    {
                      "type": "text",
                      "id": "YoHbO",
                      "fill": "$ink",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Our neighbor helped me carry him to the car. He was breathing, but in terrible pain. By the time we reached the clinic — about forty-five minutes — he had stopped talking, and his lips were turning blue.",
                      "lineHeight": 1.65,
                      "fontFamily": "Inter",
                      "fontSize": 16,
                      "fontWeight": "500"
                    }
                  ]
                },
                {
                  "type": "text",
                  "id": "lK850",
                  "name": "mPPartial",
                  "fill": "$ink-muted",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "He had been told he had high blood pressure a few years ago…",
                  "lineHeight": 1.65,
                  "fontFamily": "Inter",
                  "fontSize": 16,
                  "fontWeight": "normal",
                  "fontStyle": "italic"
                }
              ]
            }
          ]
        },
